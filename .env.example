REMNAWAVE_BASE_URL=https://vpn.example.com
REMNAWAVE_API_TOKEN=your-api-token-here

# Optional: API key for Caddy reverse proxy with custom path
# See: https://docs.remnawave.com/docs/security/caddy-with-custom-path/
# REMNAWAVE_API_KEY=your-caddy-api-key

# Optional: enable readonly mode (only read/list operations, no create/update/delete)
# REMNAWAVE_READONLY=true

# MCP runtime transport: stdio or http
# MCP_TRANSPORT=http

# HTTP MCP settings
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3100
# MCP_HTTP_PATH=/mcp
# MCP_HTTP_STATELESS=true
# MCP_ALLOW_REMOTE=false
# MCP_REDACT_SENSITIVE=true
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1

# Safe mode:
# off      - expose all tools
# balanced - hide known-sensitive tools (default)
# strict   - additional filtering for settings/metadata tools
# REMNAWAVE_SAFE_MODE=balanced
